# Financial analytics uploads (folder kept via financial-data/.gitkeep)
financial-data/*.csv

# Private spend context for LLM titling (see prompts/financial-spend-knowledge.example.md)
prompts/financial-spend-knowledge.md

# Google Calendar OAuth — any JSON under credentials/ (keep credentials/.gitkeep)
credentials/*.json
client_secret*.json
# Saved user token (filename used by app/CLIs; --token-cache can point inside the repo)
oauth-token.json

# Local model/cache artifacts
models/
.cache/
.hf-cache/
*.safetensors
*.gguf
*.bin

# Logs / scratch
*.log
scripts/.scheduler-stack/

